{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/login", "destination": "/api/login.js" },
    { "source": "/api/me", "destination": "/api/me.js" },
    { "source": "/api/sync", "destination": "/api/sync.js" },
    { "source": "/api/emails", "destination": "/api/emails.js" },
    { "source": "/api/admin/create-user", "destination": "/api/admin-create-user.js" },
    { "source": "/api/health", "destination": "/api/health.js" },
    { "source": "/(.*)", "destination": "/public/$1" },
    { "source": "/", "destination": "/public/index.html" }
  ]
}
